{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@biblebeam/verse-matcher": ["packages/verse-matcher/src"],
      "@biblebeam/bible-data": ["packages/bible-data/src"],
      "@biblebeam/stt-providers": ["packages/stt-providers/src"],
      "@biblebeam/bible-providers": ["packages/bible-providers/src"]
    }
  },
  "include": ["src/**/*", "packages/**/*"],
  "exclude": ["node_modules", "dist"]
}
